# Copy this file to .env and fill in values as needed.
# All variables are optional — defaults work with a local Ollama instance.

# LLM backend: ollama (default, no key needed), openai, or anthropic
TACS_LLM_BACKEND=ollama

# Ollama settings (used when TACS_LLM_BACKEND=ollama)
TACS_OLLAMA_BASE_URL=http://localhost:11434
TACS_OLLAMA_MODEL=llama3
TACS_OLLAMA_EMBED_MODEL=nomic-embed-text

# API keys (only required for non-ollama backends)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Generation settings
TACS_SEED=42
TACS_CONVERSATION_COUNT=50
TACS_MAX_TURNS=10

# Logging
TACS_LOG_LEVEL=INFO
